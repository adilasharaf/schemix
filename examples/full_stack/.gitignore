# ═══════════════════════════════════════════════════════════════════════════════
#  .gitignore — dart_ts_generator
#  Unified configuration for Dart/Flutter and TypeScript/Node
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dart & Flutter ───────────────────────────────────────────────────────────
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
# Omit committing pubspec.lock for library packages; see
# https://dart.dev/guides/libraries/private-files#pubspeclock.
pubspec.lock
doc/api/

# ── TypeScript & Node ────────────────────────────────────────────────────────
node_modules/
# Compiled output is committed for git-dependency TS consumers.
# If you prefer not to commit dist/, uncomment the next line:
# dist/

# ── Generated Output ─────────────────────────────────────────────────────────
# gen/ IS committed — it is the source for tsc and for git-based TS consumers.
# Do NOT add gen/ here.
build/

# ── IDEs & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
.zed/

# ── System & Misc ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
coverage/